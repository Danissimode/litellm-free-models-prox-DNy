# =============================================================================
# Aion Model Gateway — environment template
# =============================================================================
# Copy to `.env` and fill in your own values. NEVER commit a real `.env`.
#   cp .env.example .env
#
# A valid LITELLM_MASTER_KEY and POSTGRES_PASSWORD are REQUIRED — the gateway
# will refuse to start without them (see scripts/preflight.sh).
#
# Generate a strong master key:
#   openssl rand -hex 32 | sed 's/^/sk-/'
# =============================================================================

# ── Required: gateway security ───────────────────────────────────────────────
# Must start with `sk-`, must NOT be a demo/example value, ≥32 chars recommended.
LITELLM_MASTER_KEY=
# Salt for hashing virtual keys. Generate separately: openssl rand -hex 32
LITELLM_SALT_KEY=

# ── Admin UI ────────────────────────────────────────────────────────────────
# /ui is auth-gated by UI_USERNAME/UI_PASSWORD on top of master_key auth.
# Change these from the defaults.
UI_USERNAME=admin
UI_PASSWORD=

# ── Postgres (local service, not published to host) ──────────────────────────
POSTGRES_USER=litellm
POSTGRES_PASSWORD=
POSTGRES_DB=litellm
# Used verbatim by LiteLLM. Hostname `postgres` matches the compose service.
DATABASE_URL=postgresql://litellm:${POSTGRES_PASSWORD}@postgres:5432/litellm
STORE_MODEL_IN_DB=True

# ── Model sync ───────────────────────────────────────────────────────────────
SYNC_INTERVAL_HOURS=8
STARTUP_DELAY_SECONDS=60
LITELLM_BASE_URL=http://litellm:4000
# Drop models that vanish from provider APIs. Off by default for safety.
CLEANUP_STALE_MODELS=false

# ── Free-only policy ─────────────────────────────────────────────────────────
# When true, auto-discovery only registers models the provider explicitly
# marks as free (or that you manually allowlist). Ambiguous pricing is
# quarantined, never routed. See config/provider-policy.yaml.
FREE_ONLY=true

# ── Provider keys (add only the providers you use; leave others blank) ───────
OPENROUTER_API_KEY=
GROQ_API_KEY=
# Optional second Groq key for load-balancing across keys:
# GROQ_API_KEY_2=
CEREBRAS_API_KEY=
SAMBANOVA_API_KEY=
NVIDIA_NIM_API_KEY=
COHERE_API_KEY=
TOGETHER_API_KEY=
PERPLEXITY_API_KEY=
# Google Gemini — add up to 8 keys for higher free-tier RPM:
GEMINI_API_KEY=
# GEMINI_API_KEY_2=
# GEMINI_API_KEY_3=
# GEMINI_API_KEY_7=
# GEMINI_API_KEY_8=
# HuggingFace Router (HF_TOKEN, not HUGGINGFACE_API_KEY, to match LiteLLM)
HF_TOKEN=
# GitHub Models (GH_MODELS_TOKEN — GITHUB_* is reserved by GitHub Actions)
GH_MODELS_TOKEN=
MISTRAL_API_KEY=
CODESTRAL_API_KEY=
# Cloudflare Workers AI (10k neurons/day free)
CLOUDFLARE_API_KEY=
CLOUDFLARE_ACCOUNT_ID=
# Additional free-tier providers (optional)
POLLINATIONS_API_KEY=
KLUSTER_API_KEY=
LLM7_API_KEY=
ZAI_API_KEY=
PUBLICAI_API_KEY=

# ── OpenAI (PAID — leave blank unless you explicitly enable paid fallback) ────
# OPENAI_API_KEY=

# ── Observability (all OFF by default) ───────────────────────────────────────
# Langfuse self-hosted. OFF by default; enabling requires a reachable Langfuse.
ENABLE_LANGFUSE=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_OTEL_HOST=http://langfuse-web:3000

# Prometheus /metrics. OFF by default; if enabled, keep it local-only.
ENABLE_PROMETHEUS=false

# Remote bind (Tailscale/0.0.0.0). OFF by default — local-only.
ENABLE_REMOTE_BIND=false
