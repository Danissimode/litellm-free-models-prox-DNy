# =============================================================================
# opencode — Aion Model Gateway connection profile (example)
# =============================================================================
# Copy to ~/.config/opencode/.env (or wherever opencode loads env) and edit.
# Point any OpenAI-compatible agent at the gateway.
#
# SECURITY
#   - For a QUICK LOCAL TEST you may use LITELLM_MASTER_KEY directly. Never
#     ship or share it; never use the master key on a remotely-bound gateway.
#   - For regular use, create a per-agent VIRTUAL KEY instead (see
#     scripts/create-agent-keys.sh) and put THAT key here.
# =============================================================================

# Gateway endpoint (local-only by default).
OPENAI_BASE_URL=http://127.0.0.1:4000/v1

# Use a virtual key in production; the master key is fine for local testing only.
OPENAI_API_KEY=sk-create-a-virtual-key-or-use-local-master-key-only-for-testing

# Default role. opencode is primarily a coding agent → aion-programmer.
OPENCODE_MODEL=aion-programmer

# ── Role → model map (swap per task) ──────────────────────────────────────────
#   architecture / planning   →  aion-architect
#   coding    / execution     →  aion-programmer
#   review    / testing       →  aion-reviewer
#   small / low-latency tasks →  aion-fast
#
# Example: review a change
#   OPENCODE_MODEL=aion-reviewer opencode ...
